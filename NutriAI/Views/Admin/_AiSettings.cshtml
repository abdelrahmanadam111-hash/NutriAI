@model NutriAI.ViewModels.Admin.AiSettingsViewModel

<div class="card-nutri mb-4 fade-in" id="ai-settings">
    <h3 class="h5 mb-3"><i class="fas fa-robot me-2 text-success"></i>AI Settings</h3>
    <p class="small-text text-muted mb-3">Configure OpenAI credentials used for meal analysis, plans, and reports.</p>

    @if (TempData["AiSettingsSuccess"] != null)
    {
        <div class="alert alert-success py-2">@TempData["AiSettingsSuccess"]</div>
    }

    <form asp-action="AiSettings" method="post">
        @Html.AntiForgeryToken()
        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

        <div class="mb-3">
            <label asp-for="ApiKey" class="form-label"></label>
            <input asp-for="ApiKey" class="form-control form-control-nutri" type="password" autocomplete="off"
                   placeholder="@(string.IsNullOrEmpty(Model.ApiKeyLastFour) ? "sk-..." : $"Enter new key to replace ••••{Model.ApiKeyLastFour}")" />
            @if (!string.IsNullOrEmpty(Model.ApiKeyLastFour))
            {
                <div class="form-text">Current key ends with <strong>••••@Model.ApiKeyLastFour</strong>. Leave blank to keep the existing key.</div>
            }
            <span asp-validation-for="ApiKey" class="text-danger small-text"></span>
        </div>

        <div class="mb-3">
            <label asp-for="Model" class="form-label"></label>
            <select asp-for="Model" class="form-select form-control-nutri" asp-items="@(new SelectList(Model.AvailableModels, Model.Model))"></select>
            <span asp-validation-for="Model" class="text-danger small-text"></span>
        </div>

        <button type="submit" class="btn btn-nutri">
            <i class="fas fa-save me-1"></i>Save AI Settings
        </button>
    </form>
</div>
